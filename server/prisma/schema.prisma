generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * ========= ENUMS =========
 */

enum ContentLanguage {
  CZ
  EN
  DE
  FR
  IT
  ES
  PL
  NL
  SK
  HU
  RO
  PT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  FINISHED
  CANCELLED
}

enum CampaignSource {
  UNKNOWN
  LOCAL_ADMIN
  INTEGRATION
  SCHEDULER
}

enum CampaignTargetType {
  GROUP
  USER_LIST
}

enum CampaignPostSubmitActionType {
  TRAINING_PAGE
  REDIRECT_URL
}

enum CampaignLifecycleEventType {
  CREATED
  SCHEDULED
  STARTED
  FINISHED
  CANCELLED
  UPDATED
}

enum CampaignActorType {
  SYSTEM
  INTEGRATION
  USER
}

enum InteractionType {
  EMAIL_SENT
  OPENED
  CLICKED
  SUBMITTED
  REPORTED
}

enum TrainingStatus {
  PENDING
  COMPLETED
  FAILED
}

/**
 * ========= TENANT =========
 */

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users                   User[]
  groups                  Group[]
  campaigns               Campaign[]
  campaignLifecycleEvents CampaignLifecycleEvent[]
  packages                CampaignPackage[]
  templates               EmailTemplate[]
  landingPages            LandingPage[]
  trainings               TrainingModule[]
  auditLogs               AuditLog[]
  assets                  Asset[]
  senderIdentities        SenderIdentity[]
  senderDomains           SenderDomain[]
  allowedRecipientDomains AllowedRecipientDomain[]

  integrationClients IntegrationClient[]
}

model SenderDomain {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  domain    String
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  identities SenderIdentity[]

  @@unique([tenantId, domain])
}

model AllowedRecipientDomain {
  id                      Int    @id @default(autoincrement())
  tenantId                Int
  tenant                  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  integrationCompanyScope String   @default("__legacy__")
  domain                  String
  label                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenantId, integrationCompanyScope])
  @@unique([tenantId, integrationCompanyScope, domain])
}

/**
 * ========= USERS / GROUPS =========
 */

model User {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  integrationCompanyScope String   @default("__legacy__")
  email                   String
  passwordHash            String?
  firstName               String?
  lastName                String?
  fullName                String?
  department              String?
  role                    String?
  custom                  Json?
  isAdmin                 Boolean  @default(false)
  riskScore               Float    @default(0.0)
  createdAt               DateTime @default(now())
  isActive                Boolean  @default(true)
  externalUserPublicId    String?

  // relations
  groupLinks    GroupMember[]
  interactions  Interaction[]
  trainings     UserTraining[]
  campaignLinks CampaignUser[]
  auditLogs     AuditLog[]

  @@unique([tenantId, integrationCompanyScope, email])
  @@unique([tenantId, integrationCompanyScope, externalUserPublicId])
  @@index([tenantId, integrationCompanyScope, externalUserPublicId])
  @@index([tenantId, integrationCompanyScope, isActive])
}

model Group {
  id                      Int      @id @default(autoincrement())
  tenantId                Int
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrationCompanyScope String   @default("__legacy__")
  name                    String
  description             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt

  members    GroupMember[]
  targetedBy Campaign[] @relation("CampaignTargetGroup")

  @@index([tenantId, integrationCompanyScope])
  @@unique([tenantId, integrationCompanyScope, name])
}

model GroupMember {
  userId   Int
  groupId  Int
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

/**
 * ========= CONTENT (TEMPLATES / LP) =========
 */

model EmailTemplate {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  subject   String
  bodyHtml  String
  tags      String[]
  language  ContentLanguage @default(CZ)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // back-relations
  campaigns Campaign[]
  packages  CampaignPackage[] @relation("PackageEmailTemplate")

  @@unique([tenantId, language, name])
  @@index([tenantId, language, createdAt])
}

model SenderIdentity {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  fromName    String
  localPart   String
  replyTo     String?
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  senderDomainId Int
  senderDomain   SenderDomain @relation(fields: [senderDomainId], references: [id], onDelete: Cascade)

  campaigns Campaign[]        @relation("CampaignSenderIdentity")
  packages  CampaignPackage[] @relation("PackageSenderIdentity")

  @@unique([tenantId, name])
  @@unique([tenantId, senderDomainId, localPart])
}

model LandingPage {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  urlSlug   String          @unique
  html      String
  tags      String[]
  language  ContentLanguage @default(CZ)
  createdAt DateTime        @default(now())

  // back-relations
  campaigns Campaign[]
  packages  CampaignPackage[] @relation("PackageLandingPage")

  @@index([tenantId, language, createdAt])
}

/**
 * ========= CAMPAIGNS & TRACKING =========
 */

model CampaignPackage {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String?
  language    ContentLanguage @default(CZ)
  previewText String?
  isActive    Boolean         @default(true)
  isApproved  Boolean         @default(false)

  emailTemplateId Int
  emailTemplate   EmailTemplate @relation("PackageEmailTemplate", fields: [emailTemplateId], references: [id], onDelete: Restrict)

  landingPageId Int
  landingPage   LandingPage @relation("PackageLandingPage", fields: [landingPageId], references: [id], onDelete: Restrict)

  senderIdentityId Int
  senderIdentity   SenderIdentity @relation("PackageSenderIdentity", fields: [senderIdentityId], references: [id], onDelete: Restrict)

  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([tenantId, language, name])
  @@index([tenantId, language, isActive, isApproved])
}

model Campaign {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  integrationCompanyScope String                     @default("__legacy__")
  name                    String
  description             String?
  scheduledAt             DateTime
  cutoffAt                DateTime?
  startedAt               DateTime?
  finishedAt              DateTime?
  cancelledAt             DateTime?
  status                  CampaignStatus            @default(SCHEDULED)
  source                  CampaignSource            @default(UNKNOWN)
  targetType              CampaignTargetType        @default(GROUP)
  postSubmitActionType    CampaignPostSubmitActionType @default(TRAINING_PAGE)
  postSubmitRedirectUrl   String?
  recipientCountSnapshot  Int                       @default(0)
  statusReason            String?
  finishReason            String?

  packageId Int?
  package   CampaignPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  emailTemplateId Int?
  emailTemplate   EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: Restrict)

  landingPageId Int?
  landingPage   LandingPage? @relation(fields: [landingPageId], references: [id], onDelete: Restrict)

  senderIdentityId Int?
  senderIdentity   SenderIdentity? @relation("CampaignSenderIdentity", fields: [senderIdentityId], references: [id], onDelete: Restrict)

  targetGroupId Int?
  targetGroup   Group? @relation("CampaignTargetGroup", fields: [targetGroupId], references: [id], onDelete: SetNull)

  targetUsers     CampaignUser[]
  interactions    Interaction[]
  lifecycleEvents CampaignLifecycleEvent[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, integrationCompanyScope, status, scheduledAt])
  @@index([tenantId, integrationCompanyScope, status, cutoffAt])
}

model CampaignUser {
  id         Int     @id @default(autoincrement())
  campaignId Int
  userId     Int
  delivered  Boolean @default(false)

  // unikátní token pro trackování kliků / openů v rámci této kampaně
  trackingToken String @unique @default(uuid())

  // agregovaná data pro reporting (rychlé tabulky "Users" per kampaň)
  sentAt               DateTime?
  openedAt             DateTime?
  clickedAt            DateTime?
  submittedAt          DateTime?
  reportedAt           DateTime?
  externalUserPublicId String?

  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions Interaction[]

  @@unique([campaignId, userId])
  @@index([externalUserPublicId])
}

model CampaignLifecycleEvent {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  type            CampaignLifecycleEventType
  actorType       CampaignActorType          @default(SYSTEM)
  actorUserId     Int?
  actorExternalId String?
  actorEmail      String?
  actorName       String?
  actorSource     String?
  reason          String?
  meta            Json?
  createdAt       DateTime                   @default(now())

  @@index([campaignId, createdAt])
  @@index([tenantId, createdAt])
}

model IntegrationClient {
  id       Int    @id @default(autoincrement())
  tenantId Int
  name     String

  // keyId.secret je token, do DB ukládáme jen hash
  keyId   String @unique
  keyHash String @unique

  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  lastUsedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Interaction {
  id             Int             @id @default(autoincrement())
  campaignId     Int
  userId         Int
  campaignUserId Int
  type           InteractionType
  timestamp      DateTime        @default(now())
  meta           Json?

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignUser CampaignUser @relation(fields: [campaignUserId], references: [id], onDelete: Cascade)
}

/**
 * ========= TRAINING =========
 */

model TrainingModule {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  url         String // video/scorm link
  description String?
  createdAt   DateTime @default(now())

  assignments UserTraining[]
}

model UserTraining {
  id          Int            @id @default(autoincrement())
  userId      Int
  trainingId  Int
  status      TrainingStatus @default(PENDING)
  assignedAt  DateTime       @default(now())
  completedAt DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  training TrainingModule @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([userId, trainingId])
}

/**
 * ========= AUDIT =========
 */

model AuditLog {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String
  entity    String?
  entityId  Int?
  timestamp DateTime @default(now())

  @@index([tenantId, timestamp])
}

model Asset {
  id       Int    @id @default(autoincrement())
  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fileName  String
  url       String   @unique
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}
